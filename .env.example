# OpenAQ API (public — no credentials required for v3 basic access)
OPENAQ_API_KEY=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw_air_quality
KAFKA_TOPIC_PROCESSED=processed_air_quality

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_token_here
INFLUXDB_ORG=air_quality
INFLUXDB_BUCKET=air_quality

# Weights & Biases
WANDB_API_KEY=your_key_here
WANDB_PROJECT=air_quality_forecasting

# Data paths
DATA_DIR=data
